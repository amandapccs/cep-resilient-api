    "@nestjs/swagger": "^11.4.2",
    "@nestjs/testing": "^11.1.19",
    "@scalar/express-api-reference": "^0.8.48",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@types/supertest": "^7.2.0",
